rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /orders/{orderId} {
      // Guests and users can create and update orders during checkout flow
      allow create, read, update: if true;
      allow delete: if isSignedIn();
    }
    
    match /transactions/{txnId} {
      // Guests can trigger transaction records during payment
      allow create, read: if true;
      allow update, delete: if isSignedIn();
    }
    
    match /subscriptions/{subId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }
    
    match /users/{userId} {
      // Allow users to manage their own profile, or admins to see everyone
      allow read, write: if isSignedIn();
    }
    
    match /logins/{loginId} {
      allow read, write: if isSignedIn();
    }

    // Newly added collections for leads and campaign logs
    match /leads/{leadId} {
      // Anyone can submit a lead form
      allow create: if true;
      // Only authenticated admins/users can read or update leads
      allow read, update, delete: if isSignedIn();
    }

    match /campaignLogs/{logId} {
      // Anyone opening a campaign might trigger a log
      allow create: if true;
      // Only internal team can read logs
      allow read, update, delete: if isSignedIn();
    }
  }
}
